# ============================================
# Busync 프로덕션 환경변수
# 이 파일을 .env로 복사하고 실제 값을 입력하세요.
# ============================================

# ── Database ──────────────────────────────
POSTGRES_USER=busync
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password_here
POSTGRES_DB=busync_db

# ── Backend API ───────────────────────────
NODE_ENV=production
PORT=4000
JWT_SECRET=CHANGE_ME_at_least_32_chars_random_string
JWT_EXPIRES_IN=7d

# ── AI (Anthropic Claude) ────────────────
ANTHROPIC_API_KEY=sk-ant-your-api-key-here
AI_MODEL_CHAT=claude-opus-4-6
AI_MODEL_FAST=claude-haiku-4-5-20251001

# ── Frontend URLs ─────────────────────────
FRONTEND_URL=https://busync.kr
ALLOWED_ORIGINS=https://busync.kr,https://www.busync.kr

# ── Redis ─────────────────────────────────
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=

# ── SMS (CoolSMS - 선택) ─────────────────
# SMS_DEV_MODE=true 이면 콘솔에만 OTP 출력 (개발용)
SMS_DEV_MODE=false
COOLSMS_API_KEY=
COOLSMS_API_SECRET=
COOLSMS_SENDER=01000000000

# ── 카카오 로그인 (선택) ──────────────────
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
