# ============================================
# Busync 프로덕션 환경변수
# 이 파일을 .env로 복사하고 실제 값을 입력하세요.
# ============================================

# ── Database ──────────────────────────────
POSTGRES_USER=busync
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password_here
POSTGRES_DB=busync_db

# ── Backend API ───────────────────────────
NODE_ENV=production
PORT=4000
JWT_SECRET=CHANGE_ME_at_least_32_chars_random_string
JWT_EXPIRES_IN=7d

# ── AI (Anthropic Claude) ────────────────
ANTHROPIC_API_KEY=sk-ant-your-api-key-here
AI_MODEL_CHAT=claude-opus-4-6
AI_MODEL_FAST=claude-haiku-4-5-20251001

# AI 대타 충원 에이전트 — 'true' 로 설정해야 드랍 발생 시 AI 에이전트가 자율 충원을 시도한다.
# 미설정(기본) 시 결정론적 폴백: 드랍 시점 1회 알림 + 출발시간 경과 시 만료 처리만 수행.
EMERGENCY_AGENT_ENABLED=false

# ── Frontend URLs ─────────────────────────
FRONTEND_URL=https://busync.kr
ALLOWED_ORIGINS=https://busync.kr,https://www.busync.kr

# ── Redis ─────────────────────────────────
# 운영(docker-compose.prod.yml)에서는 REDIS_PASSWORD 가 필수다. 비우면 컨테이너가 뜨지 않는다.
# REDIS_URL 에도 동일 비밀번호를 포함해야 한다: redis://:<REDIS_PASSWORD>@redis:6379
REDIS_URL=redis://:CHANGE_ME_strong_redis_password@redis:6379
REDIS_PASSWORD=CHANGE_ME_strong_redis_password

# ── SMS (CoolSMS - 선택) ─────────────────
# SMS_DEV_MODE=true 이면 콘솔에만 OTP 출력 (개발용)
SMS_DEV_MODE=false
COOLSMS_API_KEY=
COOLSMS_API_SECRET=
COOLSMS_SENDER=01000000000

# ── 이메일 (nodemailer / SMTP) ────────────
# 비밀번호 재설정 인증번호 발송용.
# EMAIL_DEV_MODE=true 이면 실제 발송 대신 콘솔에 인증번호 출력 (개발용)
EMAIL_DEV_MODE=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Busync <no-reply@busync.kr>

# ── 카카오 로그인 (선택) ──────────────────
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# ── 보안 / CSP 외부 도메인 허용목록 (선택) ───
# Sentry, PostHog, Stripe 등 도입 시 코드 수정 없이 환경변수만 추가하면 됨.
# 공백으로 구분된 호스트 목록.
CSP_CONNECT_SRC_EXTRA=
CSP_SCRIPT_SRC_EXTRA=
CSP_FRAME_SRC_EXTRA=
CSP_IMG_SRC_EXTRA=

# ── Swagger API 문서 (프로덕션 디버그용 — 평소엔 비활성) ──
# ENABLE_SWAGGER=true 로 설정하면 프로덕션에서도 /api-docs 노출됨. 평소엔 비활성 유지.
ENABLE_SWAGGER=false

# ── HSTS preload (한 번 켜면 사실상 되돌리기 어려움 — 안전 절차 후에만 true) ──
# 1) 모든 서브도메인이 valid 인증서 보유 확인
# 2) HSTS_PRELOAD=true 배포 후 응답 헤더 확인
# 3) https://hstspreload.org 에 busync.kr 등록
HSTS_PRELOAD=false

# ── 감사 로그 보존 정책 ──
# 기본 90일 보유 후 일괄 삭제. 운영 정책상 더 길게 보유해야 하면 늘리거나 비활성.
AUDIT_LOG_RETENTION_DAYS=90
AUDIT_LOG_RETENTION_DISABLED=false
