# ============================================
# Busync 모바일 앱 환경변수
# ============================================
#
# ⚠️  보안 경고
# ────────────────────────────────────────────
# `EXPO_PUBLIC_*` 접두사가 붙은 모든 변수는 **빌드 시 JS 번들에 그대로 인라인됩니다**.
# 즉 앱을 디컴파일하면 누구나 값을 볼 수 있습니다.
#
# ✅ 여기에 둬도 되는 것 — 클라이언트에 노출되어도 안전한 공개 식별자
#    · API base URL
#    · 카카오 REST API 키 (도메인/번들 ID 화이트리스트로 보호되는 공개 키)
#    · Stripe publishable key
#    · Firebase web config
#
# ❌ 절대 두면 안 되는 것
#    · JWT secret · DB 비밀번호
#    · 카카오 client SECRET · OAuth client secret
#    · Stripe secret key · Anthropic API key
#    · 어떤 형태로든 백엔드만 알아야 하는 자격증명
#
# 이런 secret 들은 **백엔드 .env 에만** 두고, 모바일은 백엔드 API 를 통해서만 사용해야 합니다.

# API 서버 주소 (실제 디바이스 테스트 시 localhost 대신 컴퓨터 IP 입력)
EXPO_PUBLIC_API_BASE_URL=http://localhost:4000/api

# 카카오 로그인 - REST API 키 (https://developers.kakao.com)
# REST API 키는 공개 키. SECRET 키는 절대 여기 두지 말 것.
EXPO_PUBLIC_KAKAO_REST_API_KEY=your-kakao-rest-api-key
