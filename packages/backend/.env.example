DATABASE_URL="postgresql://user:password@localhost:5432/sungmin_bus_db"
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"
PORT=4000
NODE_ENV="development"
ANTHROPIC_API_KEY="your-anthropic-api-key"
FRONTEND_URL="http://localhost:3000"

# AI 모델 설정 (미지정 시 기본값 사용)
AI_MODEL_CHAT="claude-opus-4-6"
AI_MODEL_FAST="claude-haiku-4-5-20251001"

# CORS 허용 출처 (쉼표 구분)
ALLOWED_ORIGINS="http://localhost:3000"

# Redis (rate limiting 분산 저장소 — 미설정 시 메모리 폴백)
REDIS_URL="redis://localhost:6379"

# 카카오 로그인 (https://developers.kakao.com 에서 앱 생성)
KAKAO_CLIENT_ID="your-kakao-rest-api-key"
KAKAO_CLIENT_SECRET="your-kakao-client-secret"

# CoolSMS 문자 인증 (https://coolsms.co.kr 에서 발급)
COOLSMS_API_KEY="your-coolsms-api-key"
COOLSMS_API_SECRET="your-coolsms-api-secret"
COOLSMS_SENDER="01000000000"

# 개발 환경에서 SMS 발송 없이 콘솔에 OTP 출력 (true/false)
SMS_DEV_MODE="true"
